<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/md_theme_outlineVariant"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/item_cart_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                tools:srcCompat="@tools:sample/avatars" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/item_cart_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Premium Product Title"
                android:textColor="@color/md_theme_onSurface"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/item_cart_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="LKR 1,500.00"
                android:textColor="@color/md_theme_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/custom_input_search"
                android:backgroundTint="@color/md_theme_surfaceVariant"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/item_cart_btn_minus"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="0dp"
                    app:icon="@drawable/arrow_down_24"
                    app:iconSize="18dp"
                    app:iconTint="@color/md_theme_primary"
                    android:rotation="90"/>

                <TextView
                    android:id="@+id/item_cart_quantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="32dp"
                    android:text="1"
                    android:textAlignment="center"
                    android:textColor="@color/md_theme_onSurface"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/item_cart_btn_plus"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="0dp"
                    app:icon="@drawable/arrow_down_24"
                    app:iconSize="18dp"
                    app:iconTint="@color/md_theme_primary"
                    android:rotation="270"/>
            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/item_cart_remove"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top"
            app:icon="@drawable/delete_24px"
            app:iconTint="@color/md_theme_error" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>